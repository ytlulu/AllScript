        SaveSettings()
    end)

    -- Chose Flower (di-populate dari Scan Flower di accordion Plant)
    local flowerPlantDrop = sec:Dropdown("Chose Flower", {"[Scan dulu]"}, "[Scan dulu]", function(value)
        if value:find("%[") then SelectedPlantFlowerName = nil; return end
        SelectedPlantFlowerName = value:match("(.-)%s+X%d+") or value
    end)

    _G.SetFlowerDropOptions = function(opts)
        flowerPlantDrop:SetOptions(opts)
    end

    sec:Toggle("Loop Plant", false, function(v)
        if v then
            if not PlotFound then
                win:luluNotify("Find your plot first!", Color3.fromRGB(220, 50, 50))
                return
            end
            if IsAutoPlantRunning then
                win:luluNotify("Loop sudah jalan!", Color3.fromRGB(220, 140, 20))
                return
            end
            ClearPlantedPositions()
            spawn(function() ContinuousAutoPlant() end)
            win:luluNotify("Continuous Plant dimulai!", Color3.fromRGB(40, 180, 80))
        else
            IsAutoPlantRunning = false
            AutoPlantEnabled   = false
            win:luluNotify("Stopping...", Color3.fromRGB(220, 140, 20))
        end
    end)

    sec:Button("Start Once", function(done)
        if not PlotFound then
            win:luluNotify("Find your plot first!", Color3.fromRGB(220, 50, 50))
            return done()
        end
        LoadExistingFlowerPositions()
        AutoPlantEnabled = true

        local plotsToPlant = {}
        if PlantAllPlots then for i = 1, 6 do table.insert(plotsToPlant, i) end
        else table.insert(plotsToPlant, SelectedPlot) end

        if PlantType == "Flower" then
            if not SelectedPlantFlowerName then
                win:luluNotify("Scan & pilih flower dulu!", Color3.fromRGB(220, 50, 50))
                AutoPlantEnabled = false
                return done()
            end
            local entry = ScannedPlantFlowers[SelectedPlantFlowerName]
            local ids = entry and entry.ids
            if not ids or #ids == 0 then
                win:luluNotify("Flower ID kosong! Scan ulang.", Color3.fromRGB(220, 50, 50))
                AutoPlantEnabled = false
                return done()
            end
            win:luluNotify("Plant Flower dimulai!", Color3.fromRGB(40, 180, 80))
            spawn(function()
                local total = 0
                for _, plotNum in ipairs(plotsToPlant) do
                    if not AutoPlantEnabled then break end
                    total = total + AutoPlantGrid(
                        SelectedPlantFlowerName, plotNum, PlantMode, true, ids
                    )
                end
                AutoPlantEnabled = false
                win:luluNotify(total .. " flowers moved!", Color3.fromRGB(40, 180, 80))
                done()
            end)
        else
            if not PlantAllSeeds and not SelectedSeed and #SelectedPlantFlowers == 0 then
                win:luluNotify("Pilih seed dulu!", Color3.fromRGB(220, 50, 50))
                AutoPlantEnabled = false
                done(); return
            end
            local seedsToPlant = {}
            local allSeeds = GetAllSeeds()
            if #SelectedPlantFlowers > 0 then
                -- Seed Shop: match nama ShopFlower ke nama seed di inventori
                for _, s in ipairs(allSeeds) do
                    local internalName = GetPlantSeedName(s.Name)
                    for _, chosen in ipairs(SelectedPlantFlowers) do
                        if internalName == chosen then
                            table.insert(seedsToPlant, s.Name)
                            break
                        end
                    end
                end
            elseif PlantAllSeeds then
                for _, s in ipairs(allSeeds) do table.insert(seedsToPlant, s.Name) end
            else
                table.insert(seedsToPlant, SelectedSeed)
            end
            win:luluNotify("Auto Plant dimulai!", Color3.fromRGB(40, 180, 80))
            spawn(function()
                local total = 0
                for _, plotNum in ipairs(plotsToPlant) do
                    if not AutoPlantEnabled then break end
                    for _, seedName in ipairs(seedsToPlant) do
                        if not AutoPlantEnabled then break end
                        if GetSeedCount(seedName) > 0 then
                            total = total + AutoPlantGrid(seedName, plotNum, PlantMode, false, nil)
                            wait(1)
                        end
                    end
                end
                AutoPlantEnabled = false
                win:luluNotify(total .. " seeds planted!", Color3.fromRGB(40, 180, 80))
                done()
            end)
        end
    end, {color = Color3.fromRGB(40, 160, 60), loading = "Planting..."})

    sec:Button("Stop", function()
        AutoPlantEnabled   = false
        IsAutoPlantRunning = false
        win:luluNotify("Auto Plant dihentikan!", Color3.fromRGB(220, 50, 50))
    end, {color = Color3.fromRGB(200, 50, 50)})

end)


