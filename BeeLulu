local function GetFlowerStock(flowerName)
    local success, stock = pcall(function()
        local screen = player:WaitForChild("PlayerGui"):FindFirstChild("ScreenItemsShop")
        if not screen then return 0 end
        local shopWindow = screen:FindFirstChild("FlowerShopWindow")
        if not shopWindow then return 0 end
        local children = shopWindow:GetChildren()
        if #children < 3 then return 0 end
        local sf = children[3]:FindFirstChild("ScrollingFrame")
        if not sf then return 0 end
        local frame = sf:FindFirstChild(flowerName)
        if not frame then return 0 end
        local btn = frame:FindFirstChild("ItemButton")
        if not btn then return 0 end
        local lbl = btn:FindFirstChild("StockLabel")
        if not lbl then return 0 end
        return tonumber(lbl.Text:match("X(%d+)")) or 0
    end)
    return success and stock or 0
end

-- FIX: Renamed BuyAllFlowerStock (was BuyAllStock conflict)
local function BuyAllFlowerStock(flowerName)
    local totalBought   = 0
    local initialStock  = GetFlowerStock(flowerName)
    if initialStock <= 0 then return 0 end
    while totalBought < initialStock do
        if GetFlowerStock(flowerName) <= 0 then break end
        BuyFlower(flowerName)
        totalBought = totalBought + 1
        wait(0.4)
        if totalBought >= 100 then break end
    end
    if totalBought > 0 then Log("Bought " .. totalBought .. "x " .. flowerName) end
    return totalBought
end

-- Return: bool, table {name, count}
local function AutoBuySeeds(list)
    if not list or #list == 0 then return false, {} end
    local bought     = false
    local boughtList = {}
    for _, flowerName in ipairs(list) do
        if GetFlowerStock(flowerName) > 0 then
            local n = BuyAllFlowerStock(flowerName)
            if n > 0 then
                bought = true
                table.insert(boughtList, {name = flowerName, count = n})
            end
            task.wait(0.5)
        end
    end
    return bought, boughtList
end

