local function AutoSpawnAllBees()
    local count = 0
    if not ReadyToSpawn then return 0 end
    for i = #ReadyToSpawn, 1, -1 do
        local flower = ReadyToSpawn[i]
        if not flower then table.remove(ReadyToSpawn, i) continue end
        local hitbox = flower.Name == "Hitbox" and flower or flower:FindFirstChild("Hitbox")
        if not hitbox then continue end
        local hasBee = hitbox:GetAttribute("BeeId")
        local uid    = hitbox:GetAttribute("UniqueId")
        if not hasBee and uid then
            pcall(function()
                ReplicatedStorage.Framework.Features.HoneySystem.FlowerUtil.RemoteEvent:FireServer(
                    "SpawnFlowerBee", uid
                )
            end)
            table.remove(ReadyToSpawn, i)
            count = count + 1
        else
            table.remove(ReadyToSpawn, i)
        end
    end
    return count
end

