local ReadyToSpawn = {}

local function ScanFlowers()
    local myModel = GetMyPlotModel()
    if not myModel then return end
    local flowersFolder = myModel:FindFirstChild("Flowers")
    if not flowersFolder then return end
    for _, flower in ipairs(flowersFolder:GetChildren()) do
        if not flower or not flower.Parent then continue end
        local hitbox = flower:FindFirstChild("Hitbox") or (flower.Name == "Hitbox" and flower)
        if not hitbox then continue end
        local growAttach  = hitbox:FindFirstChild("InstantGrowAttachment")
        local spawnAttach = hitbox:FindFirstChild("SpawnBeeAttachment")
        if table.find(ReadyToSpawn, flower) or table.find(StillGrowing, flower) then continue end
        if spawnAttach and spawnAttach:FindFirstChild("InstantGrowPrompt") then
            table.insert(ReadyToSpawn, flower)
        elseif growAttach and growAttach:FindFirstChild("InstantGrowPrompt") then
            table.insert(StillGrowing, flower)
        end
    end
    for i = #StillGrowing, 1, -1 do
        local f = StillGrowing[i]
        if not f or not f.Parent then table.remove(StillGrowing, i) continue end
        local hb = f:FindFirstChild("Hitbox") or (f.Name == "Hitbox" and f)
        if hb and hb:FindFirstChild("SpawnBeeAttachment") and hb.SpawnBeeAttachment:FindFirstChild("InstantGrowPrompt") then
            table.remove(StillGrowing, i)
            table.insert(ReadyToSpawn, f)
        end
    end
end

