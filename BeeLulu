local QUEST_FILTER = {"Season Pass"}
local QUEST_STRIP  = {"Daily Quest: ","Weekly Quest: ", "Monthly Quest: ", "Seasonal Quest: "}

local function ProcessTaskDesc(rawDesc)
    for _, f in ipairs(QUEST_FILTER) do
        if rawDesc:sub(1, #f) == f then return nil end
    end
    for _, s in ipairs(QUEST_STRIP) do
        if rawDesc:sub(1, #s) == s then
            return rawDesc:sub(#s + 1)
        end
    end
    return rawDesc
end

local function GetSeasonTasks()
    local results = {}
    local ok, sf = pcall(function()
        return player.PlayerGui
            :WaitForChild("ScreenSeasonPass", 2)
            :FindFirstChild("ScreenSeasonPass")
            :FindFirstChild("Task")
            :FindFirstChild("ScrollingFrame")
    end)
    if not ok or not sf then return results end
    for _, taskObj in ipairs(sf:GetChildren()) do
        local desc  = taskObj:FindFirstChild("Desc")
        local count = taskObj:FindFirstChild("Count")
        if desc and count then
            local processedDesc = ProcessTaskDesc(desc.Text)
            if processedDesc == nil then continue end
            local cur, max = count.Text:match("(%d+)/(%d+)")
            local isDone = false
            if cur and max then isDone = tonumber(cur) >= tonumber(max) end
            table.insert(results, {desc = processedDesc, count = count.Text, isDone = isDone})
        end
    end
    table.sort(results, function(a, b)
        if a.isDone ~= b.isDone then return not a.isDone end
        return false
    end)
    return results
end

local function GetSpringData()
    local result = {}
    local activities = player:FindFirstChild("PlayerGui")
        and player.PlayerGui:FindFirstChild("GameActivities")
    if not activities then return result end
    for _, panel in ipairs(activities:GetChildren()) do
        local sf = panel:FindFirstChild("TasksFrame")
            and panel.TasksFrame:FindFirstChild("Frame")
            and panel.TasksFrame.Frame:FindFirstChild("ScrollingFrame")
        if sf then
            for _, ti in ipairs(sf:GetChildren()) do
                if ti.Name == "TaskItem" then
                    local flowersFrame  = ti:FindFirstChild("Flowers")
                    local progressFrame = ti:FindFirstChild("Progress")
                    if flowersFrame and progressFrame then
                        local progTexts = {}
                        local hasValid  = false
                        for _, step in ipairs(progressFrame:GetChildren()) do
                            local txt = step:FindFirstChild("TXT")
                            local val = txt and txt.Text or ""
                            if val ~= "" then hasValid = true end
                            table.insert(progTexts, val)
                        end
                        if hasValid then
                            local mainFlower = nil
                            for _, name in ipairs(SPRING_FLOWERS) do
                                if flowersFrame:FindFirstChild(name) then
                                    mainFlower = name; break
                                end
                            end
                            if mainFlower then
                                result[mainFlower] = result[mainFlower] or {}
                                for _, v in ipairs(progTexts) do
                                    table.insert(result[mainFlower], v)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return result
end

