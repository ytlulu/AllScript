local function IsPositionAvailable(x, z)
    for _, planted in ipairs(PlantedPositions) do
        local dist = math.sqrt((x - planted.x)^2 + (z - planted.z)^2)
        if dist < PlantCollisionRadius then return false end
    end
    return true
end

