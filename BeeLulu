local function LoadSettings()
    if not HasFileAccess() then return end
    local exists = false
    if type(isfile) == "function" then exists = isfile(SETTINGS_FILE)
    else local ok = pcall(function() readfile(SETTINGS_FILE) end); exists = ok end
    if not exists then return end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(SETTINGS_FILE))
    end)
    if not ok or type(data) ~= "table" then return end

    if data.ClaimDelay             then ClaimDelay           = data.ClaimDelay           end
    if data.SellDelay              then SellDelay            = data.SellDelay            end
    if data.BuyFlowerDelay         then BuyFlowerDelay       = data.BuyFlowerDelay       end
    if data.BuyItemsDelay          then BuyItemsDelay        = data.BuyItemsDelay        end
    if data.SmartLoopDelay         then SmartLoopDelay       = data.SmartLoopDelay       end
    if data.BuyAllFlower  ~= nil   then BuyAllFlower         = data.BuyAllFlower         end
    if data.BuyAllItems   ~= nil   then BuyAllItems          = data.BuyAllItems          end
    if data.PlantAllSeeds ~= nil   then PlantAllSeeds        = data.PlantAllSeeds        end
    if data.PlantAllPlots ~= nil   then PlantAllPlots        = data.PlantAllPlots        end
    if data.PlantMode              then PlantMode            = data.PlantMode            end
    if data.MoveStud               then MoveStud             = data.MoveStud             end
    if data.StartDirection         then StartDirection       = data.StartDirection       end
    if data.PlantCollisionRadius   then PlantCollisionRadius = data.PlantCollisionRadius end
    if data.PlantY                 then PlantY               = data.PlantY               end
    if data.WebhookURL             then WebhookURL           = data.WebhookURL           end
    if data.SeedWebhookDelay       then SeedWebhookDelay     = data.SeedWebhookDelay     end
    if data.StatusWebhookDelay     then StatusWebhookDelay   = data.StatusWebhookDelay   end
    if data.SelectedBuyFlowers   and type(data.SelectedBuyFlowers)   == "table" then
        SelectedBuyFlowers = data.SelectedBuyFlowers
    end
    if data.selectedBuyItems     and type(data.selectedBuyItems)     == "table" then
        selectedBuyItems = data.selectedBuyItems
    end
    if data.SelectedPlantFlowers and type(data.SelectedPlantFlowers) == "table" then
        SelectedPlantFlowers = data.SelectedPlantFlowers
    end
    if data.SelectedPlot then SelectedPlot = data.SelectedPlot end

    print("[Config] Settings loaded from " .. SETTINGS_FILE)
end

