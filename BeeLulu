local CONFIG_FILE = "seed_config.json"
local DEFAULT_MAPPING = {
    ["Four Leafe Clover"]  = "Clover",
    ["Morning Glory"]      = "MorningGlory",
    ["Fire Blossom"]       = "FireBlossom",
    ["Venus Fly Trap"]     = "VenusFlyTrap",
    ["Kniphofia Uvaria"]   = "KniphofiaUvaria",
    ["Aquilegia Coerulea"] = "AquilegiaCoerulea",
    ["Red Rose"]           = "RedRose",
    ["Blue Bell"]          = "Bluebell",
    ["Sun Flower"]         = "Sunflower",
}

local SeedNameMapping = {}

local function HasFileAccess()
    return type(readfile) == "function" and type(writefile) == "function"
end

local function WriteJsonConfig(mapping)
    if not HasFileAccess() then print("Executor tidak support readfile/writefile") return false end
    local ok, err = pcall(function()
        local entries = {}
        for k, v in pairs(mapping) do table.insert(entries, '    "' .. k .. '": "' .. v .. '"') end
        table.sort(entries)
        local pretty = "{\n" .. table.concat(entries, ",\n") .. "\n}"
        writefile(CONFIG_FILE, pretty)
    end)
    if ok then print("seed_config.json updated") return true
    else print("Gagal tulis: " .. tostring(err)) return false end
end

local function ReadJsonConfig()
    if not HasFileAccess() then
        print("Pakai default mapping")
        return nil
    end
    local exists = false
    if type(isfile) == "function" then exists = isfile(CONFIG_FILE)
    else local ok = pcall(function() readfile(CONFIG_FILE) end); exists = ok end
    if not exists then
        WriteJsonConfig(DEFAULT_MAPPING)
        return DEFAULT_MAPPING
    end
    local ok, result = pcall(function() return HttpService:JSONDecode(readfile(CONFIG_FILE)) end)
    if ok and result and type(result) == "table" then return result
    else return DEFAULT_MAPPING end
end

local function LoadSeedConfig()
    local mapping = ReadJsonConfig()
    SeedNameMapping = {}
    for k, v in pairs(mapping or DEFAULT_MAPPING) do SeedNameMapping[k] = v end
end

local function ReloadSeedConfig()
    LoadSeedConfig()
    local count = 0; for _ in pairs(SeedNameMapping) do count = count + 1 end
    return count
end

local function PrintSeedMappings()
    local sorted = {}
    for k in pairs(SeedNameMapping) do table.insert(sorted, k) end
    table.sort(sorted)
    print("SEED MAPPINGS ")
    for _, k in ipairs(sorted) do print('  "' .. k .. '" → "' .. SeedNameMapping[k] .. '"') end
    print("Total: " .. #sorted)
end

local DiscoveredSeeds = {}

local function ToCamelCase(displayName)
    local result = ""
    for word in displayName:gmatch("%S+") do
        result = result .. word:sub(1,1):upper() .. word:sub(2)
    end
    return result
end

local function GetPlantSeedName(displayName)
    if SeedNameMapping[displayName] then return SeedNameMapping[displayName] end
    if not DiscoveredSeeds[displayName] then
        DiscoveredSeeds[displayName] = true
        local camelCase = ToCamelCase(displayName)
        SeedNameMapping[displayName] = camelCase
        print("NEW SEED: " .. displayName .. " → " .. camelCase)
        spawn(function() WriteJsonConfig(SeedNameMapping) end)
    end
    return SeedNameMapping[displayName]
end

