local function LinearInterpolate(startPos, endPos, steps)
    local positions = {}
    for i = 0, steps do
        local t = steps > 0 and (i / steps) or 0
        table.insert(positions, {
            x = startPos.x + (endPos.x - startPos.x) * t,
            y = startPos.y + (endPos.y - startPos.y) * t,
            z = startPos.z + (endPos.z - startPos.z) * t,
        })
    end
    return positions
end

local function AutoPlantZigZag(seedName, plotNumber, mode)
    local corners = GetPlotCorners(plotNumber)
    if not corners.p1 then Log("Plot " .. plotNumber .. " tidak ditemukan") return 0 end
    local startCorner = StartDirection == 3 and corners.p3 or corners.p4
    local endCorner   = StartDirection == 3 and corners.p1 or corners.p2
    local stepsAlong  = math.floor(math.abs(endCorner.z - startCorner.z) / MoveStud)
    local stepsAcross = math.floor(math.abs(corners.p1.x - corners.p2.x) / MoveStud)
    local totalPlanted = 0
    for row = 0, stepsAcross do
        if not AutoPlantEnabled then break end
        if GetSeedCount(seedName) <= 0 then Log("Seed " .. seedName .. " habis") break end
        local t = stepsAcross > 0 and (row / stepsAcross) or 0
        local rowStartX = startCorner.x + (endCorner.x - startCorner.x) * t
        local rowEndX   = rowStartX
        local rowStartZ = startCorner.z
        local rowEndZ   = endCorner.z
        local forward   = row % 2 == 0
        local positions = LinearInterpolate(
            {x=rowStartX, y=startCorner.y, z = forward and rowStartZ or rowEndZ},
            {x=rowEndX,   y=startCorner.y, z = forward and rowEndZ   or rowStartZ},
            stepsAlong
        )
        for _, pos in ipairs(positions) do
            if not AutoPlantEnabled then break end
            if GetSeedCount(seedName) <= 0 then break end
            if PlantSeedAt(seedName, pos.x, pos.y, pos.z, mode, plotNumber) then
                totalPlanted = totalPlanted + 1
            end
        end
    end
    return totalPlanted
end

local function ContinuousAutoPlant()
    IsAutoPlantRunning = true
    while IsAutoPlantRunning do
        local seeds = GetAllSeeds()
        if #seeds == 0 then
            Log("Tidak ada seed di backpack, menunggu...")
            wait(5)
        else
            AutoPlantEnabled = true
            ClearPlantedPositions()
            local seedsToPlant = {}
            if #SelectedPlantFlowers > 0 then
                for _, s in ipairs(seeds) do
                    local internalName = GetPlantSeedName(s.Name)
                    for _, chosen in ipairs(SelectedPlantFlowers) do
                        if internalName == chosen then
                            table.insert(seedsToPlant, s.Name)
                            break
                        end
                    end
                end
            elseif PlantAllSeeds then
                for _, s in ipairs(seeds) do table.insert(seedsToPlant, s.Name) end
            elseif SelectedSeed then
                table.insert(seedsToPlant, SelectedSeed)
            end
            local plotsToPlant = {}
            if PlantAllPlots then for i = 1, 6 do table.insert(plotsToPlant, i) end
            elseif SelectedPlot then table.insert(plotsToPlant, SelectedPlot) end
            for _, plotNum in ipairs(plotsToPlant) do
                if not IsAutoPlantRunning then break end
                for _, seedName in ipairs(seedsToPlant) do
                    if not IsAutoPlantRunning then break end
                    if GetSeedCount(seedName) > 0 then
                        AutoPlantZigZag(seedName, plotNum, PlantMode)
                        wait(1)
                    end
                end
            end
            AutoPlantEnabled = false
            wait(2)
        end
    end
    IsAutoPlantRunning = false
end

