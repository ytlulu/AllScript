local function FindPlotCoordinates()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then
        return false, "Character belum load!"
    end

    local AWAL_REF  = PlotCoordinates[1]
    local playerPos = root.Position

    local lookFlat = Vector3.new(root.CFrame.LookVector.X, 0, root.CFrame.LookVector.Z)
    local playerCF = CFrame.new(playerPos, playerPos + lookFlat)

    ResolvedPlotCoords = {}
    local count = 0

    for _, coord in ipairs(PlotCoordinates) do
        if coord.name ~= "Awal" then
            local dx = coord.x - AWAL_REF.x
            local dy = coord.y - AWAL_REF.y
            local dz = coord.z - AWAL_REF.z
            local worldPos = playerCF * Vector3.new(dx, dy, dz)
            ResolvedPlotCoords[coord.name] = {
                name = coord.name,
                x    = worldPos.X,
                y    = worldPos.Y,
                z    = worldPos.Z,
            }
            count = count + 1
            Log(string.format("[FindPlot] %s → (%.2f, %.2f, %.2f)",
                coord.name, worldPos.X, worldPos.Y, worldPos.Z))
        end
    end

    PlotFound = true
    return true, count .. " corners resolved"
end

