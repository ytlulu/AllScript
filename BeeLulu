                   obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                    obj.Enabled = false; pCount = pCount + 1
                end
            end
            local myModel = GetMyPlotModel()
            local cCount  = 0
            for _, obj in pairs(workspace:GetDescendants()) do
                if (obj:IsA("BasePart") or obj:IsA("MeshPart"))
                   and not (myModel and obj:IsDescendantOf(myModel)) then
                    obj.Color    = Color3.fromRGB(0, 0, 0)
                    obj.Material = Enum.Material.SmoothPlastic
                    cCount = cCount + 1
                end
            end
            win:luluNotify(pCount .. " effects off | " .. cCount .. " parts black", Color3.fromRGB(40, 160, 60))
        end, {color = Color3.fromRGB(200, 50, 50)})
    end)

end)

