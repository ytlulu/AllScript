local function DoAutoTrade()
    if not TradeFlowerName  then Log("Pilih flower dulu!") return end
    if not TradeTargetPlayer then Log("Pilih target player dulu!") return end

    local targetStillInGame = false
    for _, p in ipairs(Players:GetPlayers()) do
        if p == TradeTargetPlayer then targetStillInGame = true break end
    end
    if not targetStillInGame then
        Log("Target player sudah keluar!")
        return
    end

    local entry = ScannedBackpackFlowers[TradeFlowerName]
    if not entry or #entry.ids == 0 then Log("Tidak ada ID — scan ulang!") return end

    local ids    = entry.ids
    local toSend    = math.min(TradeAmount, #ids)
    local sentCount = 0
    local usedIds   = {}

    Log("Trade START | " .. TradeFlowerName .. " x" .. toSend)

    for i = 1, toSend do
        if not AutoTradeEnabled then Log("Trade dihentikan") break end
        local idToSend = nil
        for _, id in ipairs(ids) do
            if not usedIds[id] then idToSend = id break end
        end
        if not idToSend then Log("Tidak cukup ID") break end
        usedIds[idToSend] = true
        pcall(function()
            ReplicatedStorage.Framework.Features.GiftSystem.GiftUtil.RemoteEvent:FireServer(
                "GiveGift", TradeTargetPlayer, "Flower", idToSend
            )
        end)
        sentCount = sentCount + 1
        if i < toSend and AutoTradeEnabled then wait(1) end
    end

    Log("Trade selesai: " .. sentCount .. "/" .. toSend)
end

